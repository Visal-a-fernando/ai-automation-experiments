# Copy to .env and fill in.

# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Your numeric Telegram user ID (DM @userinfobot to find it),
# or run the bot once and send /whoami. Comma-separated for multiple.
# Leave blank to allow ANYONE who finds the bot — do not do that in prod.
TELEGRAM_ALLOWED_USER_IDS=123456789

