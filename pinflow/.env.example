# PinFlow — copy to .env and fill locally. NEVER commit .env.
# PinFlow uses a headless LLM CLI (the `claude` binary) for its 3 "thinking"
# steps (scoring, listing copy, SEO blog); auth is via that CLI's own login.

# Shopify — either a static Admin API token OR the OAuth client pair
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_TOKEN=                       # optional static token (shpat_...)
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# CJ Dropshipping (token is fetched/cached to cj_token.json at runtime)
CJ_EMAIL=your_cj_email
CJ_API_KEY=your_cj_api_key

# Telegram alerts (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT=your_telegram_chat_id
